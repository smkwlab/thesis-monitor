# Thesis Monitor Configuration Example
# Copy this file to ~/.config/thesis-monitor/config.yml and customize
# (or run `thesis-monitor init` to generate one)

# GitHub Settings
# Token resolution order: this file > GITHUB_TOKEN env > gh CLI (gh auth token)
# github_token: "your_github_token_here"

# GitHub organization. There is no built-in default (issue #28): running with no
# github_org would otherwise silently target another org's registry. When unset,
# it is derived from the registry_repo owner below; if neither is set, commands
# stop with an explicit error (run `thesis-monitor init --org <your-org>`).
github_org: "your-org"

# Registry data repository (owner/repo, read via the GitHub contents API).
# When unset, "<github_org>/thesis-student-registry" is used by convention.
# Setting only this (with github_org unset) also fills github_org from its owner.
registry_repo: "your-org/thesis-student-registry"

# Student roster CSV for name resolution (optional).
# When unset, "~/.config/<github_org>/students.csv" is used by convention
# if it exists (registry-manager reads the same conventional path).
# The roster contains personal information: keep it as a LOCAL file only —
# never commit it to any repository or to the registry.
# csv_path: "/path/to/students.csv"

# Cache Settings (registry API responses are cached here)
cache_dir: "~/.cache/thesis-monitor"
cache_ttl: 1800  # 30 minutes

# API Settings
max_concurrency: 10
timeout: 10000  # 10 seconds
